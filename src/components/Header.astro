---
// Shared Production Navigation Layout with Asset Integration
import { Image } from 'astro:assets';
import brandLogo from '../assets/01-brand-logo.svg';
---
<header class="w-full bg-corporate-navy border-b border-corporate-premiumBlue sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-white p-1 rounded">
            <img src="/src/assets/01-brand-logo.svg" alt="Johal & Company Corporate Logo" class="w-full h-full object-contain" />
          </div>
          <div class="flex flex-col">
            <span class="text-xl font-black tracking-tight text-white">JOHAL & COMPANY</span>
            <span class="text-xs tracking-widest text-corporate-accentIce font-medium">CHARTERED CERTIFIED ACCOUNTANTS</span>
          </div>
        </a>
      </div>

      <nav class="hidden md:flex space-x-8">
        <a href="/" class="text-white hover:text-corporate-accentIce text-sm font-medium transition-colors">Home</a>
        <a href="/#about" class="text-corporate-slateLight hover:text-corporate-accentIce text-sm font-medium transition-colors">About Us</a>
        <a href="/#services" class="text-corporate-slateLight hover:text-corporate-accentIce text-sm font-medium transition-colors">Services</a>
        <a href="/#testimonials" class="text-corporate-slateLight hover:text-corporate-accentIce text-sm font-medium transition-colors">Testimonials</a>
        <a href="/#contact" class="text-corporate-slateLight hover:text-corporate-accentIce text-sm font-medium transition-colors">Contact</a>
      </nav>

      <div class="hidden lg:flex items-center space-x-4">
        <a href="https://www.johalandcompany.com/bookkeeping" target="_blank" rel="noopener noreferrer" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-white border border-corporate-accentIce rounded hover:bg-corporate-accentIce hover:text-corporate-navy transition-all">
          Online Bookkeeping Area
        </a>
        <a href="https://www.johalandcompany.com/portal" target="_blank" rel="noopener noreferrer" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-corporate-navy bg-corporate-accentIce rounded hover:bg-white transition-all shadow-md">
          Client Portal
        </a>
      </div>

    </div>
  </div>
</header>
