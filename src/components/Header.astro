---
// Shared Production Navigation Hub - Capitalized Directory Routing
---
<header class="w-full bg-[#0b132b] border-b border-[#3a506b] sticky top-0 z-50 shadow-xl">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center space-x-3 group">
          <div class="w-10 h-10 bg-white p-1 rounded transition-transform group-hover:scale-105">
            <img src="/Assets/image_21.png" alt="Johal & Company Corporate Logo" class="w-full h-full object-contain" />
          </div>
          <div class="flex flex-col">
            <span class="text-lg font-black tracking-tight text-white group-hover:text-cyan-400 transition-colors">JOHAL & COMPANY</span>
            <span class="text-[10px] tracking-widest text-slate-400 font-bold">CHARTERED CERTIFIED ACCOUNTANTS</span>
          </div>
        </a>
      </div>

      <nav class="hidden md:flex space-x-8">
        <a href="/" class="text-white hover:text-cyan-400 text-sm font-medium transition-colors">Home</a>
        <a href="/#about" class="text-slate-300 hover:text-cyan-400 text-sm font-medium transition-colors">About</a>
        <a href="/#services" class="text-slate-300 hover:text-cyan-400 text-sm font-medium transition-colors">Sectors</a>
        <a href="/#testimonials" class="text-slate-300 hover:text-cyan-400 text-sm font-medium transition-colors">Testimonials</a>
        <a href="/#contact" class="text-slate-300 hover:text-cyan-400 text-sm font-medium transition-colors">Contact</a>
      </nav>

      <div class="hidden lg:flex items-center space-x-4">
        <a href="https://securedwebapp.com/login.asp?p=8155" target="_blank" rel="noopener noreferrer" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-white border border-cyan-400 rounded hover:bg-cyan-400 hover:text-[#0b132b] transition-all">
          Online Bookkeeping Area
        </a>
        <a href="https://johalandcompany.irisopenspace.co.uk/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-[#0b132b] bg-cyan-400 rounded hover:bg-white transition-all shadow-lg">
          Client Portal
        </a>
      </div>

    </div>
  </div>
</header>
