---
// Reusable Client Entry Gateways Component
---
<section id="gateways" class="w-full py-16 bg-corporate-slateLight">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-black tracking-tight text-corporate-navy sm:text-4xl">Secure Digital Accounting Infrastructure</h2>
      <p class="mt-4 text-lg text-corporate-slateText max-w-2xl mx-auto">Access your corporate accounting ledgers and secure cloud auditing vaults through our verified portals.</p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      
      <div class="bg-white p-8 rounded-lg border border-slate-200 shadow-lg flex flex-col justify-between transition-transform hover:-translate-y-1">
        <div>
          <div class="w-12 h-12 bg-corporate-navy rounded flex items-center justify-center mb-6 text-corporate-accentIce font-bold text-xl">Ω</div>
          <h3 class="text-2xl font-bold text-corporate-navy mb-2">Online Bookkeeping Area</h3>
          <p class="text-corporate-slateText mb-6">Execute corporate ledger management, record VAT transactions, and monitor real-time business account sheets securely.</p>
        </div>
        <a href="#bookkeeping-external-link" class="w-full text-center py-3 px-4 font-bold uppercase tracking-wider text-white bg-corporate-navy hover:bg-corporate-premiumBlue rounded transition-colors block">
          Launch Bookkeeping Console
        </a>
      </div>

      <div class="bg-white p-8 rounded-lg border border-slate-200 shadow-lg flex flex-col justify-between transition-transform hover:-translate-y-1">
        <div>
          <div class="w-12 h-12 bg-corporate-darkBlue rounded flex items-center justify-center mb-6 text-corporate-accentIce font-bold text-xl">§</div>
          <h3 class="text-2xl font-bold text-corporate-navy mb-2">Secure Client Portal</h3>
          <p class="text-corporate-slateText mb-6">Transmit year-end auditing documents, access payroll schedules, and review sensitive corporate tax advisory materials securely.</p>
        </div>
        <a href="#portal-external-link" class="w-full text-center py-3 px-4 font-bold uppercase tracking-wider text-corporate-navy bg-corporate-accentIce hover:bg-corporate-navy hover:text-white rounded transition-colors block shadow-md">
          Enter Encrypted Portal
        </a>
      </div>

    </div>
  </div>
</section>
