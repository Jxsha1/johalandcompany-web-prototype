---
// Interactive Portal Infrastructure Blocks
---
<section id="gateways" class="w-full py-20 bg-slate-50 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-black tracking-tight text-[#0b132b] sm:text-4xl">Client Login Infrastructure</h2>
      <p class="mt-4 text-lg text-slate-600 max-w-2xl mx-auto">Access your corporate transaction environments and encrypted financial vaults instantly.</p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      
      <div class="bg-white rounded-xl border border-slate-200 shadow-xl overflow-hidden flex flex-col justify-between group hover:border-[#3a506b] transition-all duration-300">
        <div class="p-8">
          <div class="h-48 w-full rounded-lg overflow-hidden mb-6 relative">
            <img src="/src/assets/image_4.png" alt="Bookkeeping Access Layout" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-slate-900/10"></div>
          </div>
          <h3 class="text-2xl font-bold text-[#0b132b] mb-2">Online Bookkeeping Area</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Execute real-time ledger auditing, reconcile business corporate accounts, and track transactional records securely through our cloud-hosted tracking interface.
          </p>
        </div>
        <div class="p-8 pt-0">
          <a href="https://securedwebapp.com/login.asp?p=8155" target="_blank" rel="noopener noreferrer" class="w-full text-center py-4 px-4 font-bold uppercase tracking-wider text-white bg-[#0b132b] hover:bg-[#3a506b] rounded-lg transition-colors block shadow-md">
            Launch Bookkeeping Console
          </a>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 shadow-xl overflow-hidden flex flex-col justify-between group hover:border-cyan-400 transition-all duration-300">
        <div class="p-8">
          <div class="h-48 w-full rounded-lg overflow-hidden mb-6 relative">
            <img src="/src/assets/image_5.png" alt="Iris Portal Access Layout" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-slate-900/10"></div>
          </div>
          <h3 class="text-2xl font-bold text-[#0b132b] mb-2">Secure Client Portal</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Transmit statutory accounts documents, access secure payroll records, and review sensitive taxation metrics within an encrypted Iris compliance container.
          </p>
        </div>
        <div class="p-8 pt-0">
          <a href="https://johalandcompany.irisopenspace.co.uk/" target="_blank" rel="noopener noreferrer" class="w-full text-center py-4 px-4 font-bold uppercase tracking-wider text-[#0b132b] bg-cyan-400 hover:bg-[#0b132b] hover:text-white rounded-lg transition-colors block shadow-md">
            Enter Encrypted Iris Portal
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
