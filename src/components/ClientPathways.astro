---
// Interactive Portal Infrastructure Blocks - Realignment of Portal Icons
---
<section id="gateways" class="w-full py-16 bg-slate-50 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      
      <!-- Bookkeeping Gateway Card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-lg p-8 flex flex-col justify-between group hover:border-[#3a506b] transition-all duration-300">
        <div>
          <div class="w-14 h-14 bg-slate-100 rounded-lg flex items-center justify-center mb-6 border border-slate-200 shadow-inner">
            <img src="/Assets/image_23.png" alt="Online Bookkeeping Portal Icon" class="w-8 h-8 object-contain" />
          </div>
          <h3 class="text-2xl font-bold text-[#0b132b] mb-2">Online Bookkeeping Access</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">
            Log in directly to input day to day corporate transactions, monitor ledger updates, and track balance assets through our synchronized cloud accounting engine.
          </p>
        </div>
        <a href="https://securedwebapp.com/login.asp?p=8155" target="_blank" rel="noopener noreferrer" class="w-full text-center py-4 font-bold uppercase tracking-wider text-white bg-[#0b132b] hover:bg-[#3a506b] rounded-lg transition-colors block shadow-md">
          Launch Bookkeeping Console
        </a>
      </div>

      <!-- Iris OpenSpace Gateway Card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-lg p-8 flex flex-col justify-between group hover:border-cyan-400 transition-all duration-300">
        <div>
          <div class="w-14 h-14 bg-slate-100 rounded-lg flex items-center justify-center mb-6 border border-slate-200 shadow-inner">
            <img src="/Assets/image_24.png" alt="Secure Client Portal Icon" class="w-8 h-8 object-contain" />
          </div>
          <h3 class="text-2xl font-bold text-[#0b132b] mb-2">Secure Client Portal Access</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">
            Safely transmit statutory auditing materials, access workforce payroll accounts, and review year end corporate tax profiles within an encrypted Iris OpenSpace portal.
          </p>
        </div>
        <a href="https://johalandcompany.irisopenspace.co.uk/" target="_blank" rel="noopener noreferrer" class="w-full text-center py-4 font-bold uppercase tracking-wider text-[#0b132b] bg-cyan-400 hover:bg-[#0b132b] hover:text-white rounded-lg transition-colors block shadow-md">
          Enter Encrypted Iris Portal
        </a>
      </div>

    </div>
  </div>
</section>
