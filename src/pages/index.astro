---
import '../styles/global.css';
const pageTitle = "Johal & Company | Chartered Certified Accountants & Registered Auditors";
---

<html lang="en-GB">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body class="bg-corporate-slateLight text-corporate-navy font-sans antialiased">
		<main class="min-h-screen flex flex-col justify-center items-center p-6 text-center bg-gradient-to-b from-corporate-navy to-corporate-darkBlue text-white">
			<h1 class="text-5xl font-black tracking-tight mb-4 text-corporate-accentIce">Johal & Company</h1>
			<p class="text-xl text-corporate-slateLight max-w-2xl opacity-90">Premium Accounting, Statutory Audit and Corporate Risk Mitigation Frameworks</p>
		</main>
	</body>
</html>
