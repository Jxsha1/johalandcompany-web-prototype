---
import Layout from '../layouts/Layout.astro';
import ClientPathways from '../components/ClientPathways.astro';
import ContactForm from '../components/ContactForm.astro';

const coreSectors = [
  { name: 'Bookkeeping', slug: 'bookkeeping', img: '/src/assets/image_11.jpg', desc: 'Secure ledger synchronization and digital cash records execution.' },
  { name: 'VAT', slug: 'vat', img: '/src/assets/image_12.jpg', desc: 'Making Tax Digital processing and reporting optimization.' },
  { name: 'Accounting', slug: 'accounting', img: '/src/assets/image_13.jpg', desc: 'Statutory year-end accounts generation for company directors.' },
  { name: 'Audit', slug: 'audit', img: '/src/assets/image_8.jpg', desc: 'Regulated statutory auditing protecting corporate validation lines.' },
  { name: 'Tax', slug: 'tax', img: '/src/assets/image_6.jpg', desc: 'Advanced corporate corporate tax architecture planning.' },
  { name: 'Payroll', slug: 'payroll', img: '/src/assets/image_14.jpg', desc: 'Complete RTI workforce salary structuring loops.' },
  { name: 'Business Start Ups', slug: 'business-start-ups', img: '/src/assets/image_10.jpg', desc: 'Elite incorporation layouts removing legacy textual errors.' },
  { name: 'Corporate Finance', slug: 'corporate-finance', img: '/src/assets/image_9.jpg', desc: 'Sophisticated capital sourcing and asset advisory tracks.' },
  { name: 'Company Statutory Records', slug: 'company-statutory-records', img: '/src/assets/image_15.jpg', desc: 'Companies House administrative compliance management.' },
  { name: 'Enquiries & Investigations', slug: 'enquiries-investigations', img: '/src/assets/image_16.jpg', desc: 'Defensive support architectures for active HMRC reviews.' },
  { name: 'Research & Development Claims', slug: 'research-development-claims', img: '/src/assets/image_17.jpg', desc: 'Financial engineering maximizing local corporate tax relief.' }
];
---
<Layout title="Chartered Certified Accountants & Registered Auditors">
  
  <section class="relative bg-gradient-to-b from-[#1c2541] to-[#0b132b] text-white py-32 overflow-hidden">
    <div class="absolute inset-0 opacity-15 bg-[url('/src/assets/image_1.jpg')] bg-cover bg-center mix-blend-overlay"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      
      <div class="inline-flex items-center space-x-2 bg-[#0b132b]/90 border border-[#3a506b] rounded-full py-1.5 px-4 mb-8 backdrop-blur-sm">
        <img src="/src/assets/image_2.png" alt="ACCA" class="h-4 w-auto bg-white rounded-sm" />
        <span class="text-[10px] font-black tracking-widest text-cyan-400 uppercase">ACCA Registered Statutory Auditors</span>
      </div>

      <h1 class="text-4xl sm:text-6xl font-black tracking-tight leading-tight mb-6">
        Authoritative Accountancy.<br />
        <span class="text-cyan-400">Absolute Asset Protection.</span>
      </h1>
      
      <p class="text-lg sm:text-xl text-slate-300 max-w-3xl mx-auto mb-10 leading-relaxed">
        We bridge the gap between traditional regulatory precision and clean infrastructure mechanics. Protecting over 35 years of local enterprise trust in Hornchurch.
      </p>

      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="#services" class="w-full sm:w-auto px-8 py-4 bg-cyan-400 text-[#0b132b] font-bold uppercase tracking-wider text-xs rounded shadow-lg hover:bg-white transition-colors">
          Explore Service Sectors
        </a>
        <a href="#about" class="w-full sm:w-auto px-8 py-4 border border-slate-400 text-white font-bold uppercase tracking-wider text-xs rounded hover:bg-white/10 transition-colors">
          Corporate History
        </a>
      </div>

    </div>
  </section>

  <ClientPathways />

  <section id="about" class="w-full py-24 bg-white border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        
        <div class="relative rounded-xl overflow-hidden shadow-2xl border border-slate-200 group">
          <img src="/src/assets/image_7.jpg" alt="Johal & Company Corporate Workspace" class="w-full h-auto object-cover group-hover:scale-101 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent"></div>
        </div>

        <div class="space-y-6">
          <div class="text-xs font-bold uppercase tracking-widest text-[#3a506b]">Established 1991</div>
          <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-[#0b132b]">Over 35 Years of Local Professional Authority</h2>
          
          <p class="text-slate-600 text-base leading-relaxed">
            Johal & Company has been operating for over 35 years as an accountancy practice. Over this period it has established a reputation of providing an excellent personal service to its clients. We pride ourselves on putting the needs of our clients at the forefront of everything that we do. Our services are designed according to the goals and aspirations of our clients.
          </p>

          <p class="text-slate-600 text-base leading-relaxed">
            We have assisted a whole range of individuals and organisations in different sectors and of varying sizes. Moving forward into 2026, we are reinforcing our delivery framework by coupling our deep statutory knowledge with hardened cloud storage pathways to defend our clients from financial disruption.
          </p>

          <div class="pt-4 border-t border-slate-100 flex items-center space-x-6">
            <div>
              <div class="text-2xl font-black text-[#0b132b]">35+</div>
              <div class="text-xs text-slate-500 uppercase font-bold tracking-wider">Years Active</div>
            </div>
            <div>
              <div class="text-2xl font-black text-[#0b132b]">100%</div>
              <div class="text-xs text-slate-500 uppercase font-bold tracking-wider">ACCA Aligned</div>
            </div>
            <div>
              <div class="text-2xl font-black text-[#0b132b]">£4M+</div>
              <div class="text-xs text-slate-500 uppercase font-bold tracking-wider">Client Scale Protected</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section id="services" class="w-full py-24 bg-slate-50 border-t border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center max-w-3xl mx-auto mb-20">
        <h2 class="text-3xl font-black tracking-tight text-[#0b132b] sm:text-4xl">Specialised Accounting Sectors</h2>
        <p class="mt-4 text-base text-slate-600 leading-relaxed">
          Select an operational vertical to explore our strict administrative configurations, cloud data pipelines, and corporate compliance frameworks.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {coreSectors.map((sec) => (
          <div class="bg-white rounded-xl border border-slate-200 shadow-md overflow-hidden hover:shadow-xl hover:border-[#3a506b] transition-all duration-300 flex flex-col justify-between group">
            <div class="relative h-40 overflow-hidden bg-[#0b132b]">
              <img src={sec.img} alt={sec.name} class="w-full h-full object-cover opacity-90 group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-6 flex-grow flex flex-col justify-between">
              <div>
                <h3 class="text-lg font-bold text-[#0b132b] mb-2">{sec.name}</h3>
                <p class="text-xs text-slate-600 leading-relaxed mb-4">{sec.desc}</p>
              </div>
              <a href={`/services/${sec.slug}`} class="text-xs font-bold text-[#3a506b] hover:text-cyan-400 flex items-center space-x-1 mt-2">
                <span>Access Detailed Directory</span>
                <span>→</span>
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <section id="testimonials" class="w-full py-24 bg-white relative">
    <div class="absolute inset-0 opacity-5 bg-[url('/src/assets/image_19.jpg')] bg-cover bg-center"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <div class="inline-flex items-center justify-center w-12 h-12 bg-slate-50 rounded-full border border-slate-200 text-cyan-400 font-serif text-3xl mb-6 shadow-sm">“</div>
      
      <blockquote class="text-xl sm:text-2xl font-medium text-[#0b132b] leading-relaxed max-w-4xl mx-auto mb-8 italic">
        I and my family have known Jas and Johal & Company for over 12 years. I was a Director of an international engineering company trading with turnover close to £4 million with over 40 employees, and whose accounts, payroll, tax and financial planning has managed impeccably by the partnership team.
      </blockquote>

      <div class="space-y-1">
        <div class="text-xs font-black uppercase tracking-widest text-[#0b132b]">Managing Director & Senior Shareholder</div>
        <div class="text-[11px] font-bold text-slate-600 uppercase tracking-wider">International Engineering Enterprise (Turnover Threshold: £4,000,000)</div>
      </div>
    </div>
  </section>

  <ContactForm />

</Layout>
