---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const serviceMatrix = [
    {
      slug: 'bookkeeping',
      title: 'Online Bookkeeping Services',
      img: '/Assets/image_11.jpg',
      para1: 'Managing modern ledgers demands consistent record keeping and automated synchronization loop designs. Our specialized bookkeeping architecture transitions local businesses away from disorganized paperwork by implementing clean cloud tracking channels.',
      para2: 'Every entry is recorded in strict alignment with regional corporate accounting protocols. This gives business directors complete visibility over their operating cash sheets while keeping everything entirely prepared for seasonal VAT reconciliation lines.',
      items: ['Digital transaction indexing and processing', 'Reconciliation loops against corporate bank paths', 'Cloud asset receipt scanning integration', 'Continuous ledger data balancing adjustments']
    },
    {
      slug: 'vat',
      title: 'VAT Compliance & Submissions',
      img: '/Assets/image_12.jpg',
      para1: 'Value Added Tax calculations represent a significant operational risk path if handled without professional oversight. We run thorough compliance audits to verify that your business outputs align exactly with Making Tax Digital parameters.',
      para2: 'We process your sales transactions, identify valid cross-border trade exclusions, and execute electronic filings directly to HM Revenue and Customs. This keeps your firm completely protected against late delivery penalties or calculation drops.',
      items: ['Making Tax Digital secure API processing', 'Quarterly tax liability analytics reports', 'Input versus output calculation reviews', 'Direct representation during HMRC status checks']
    },
    {
      slug: 'accounting',
      title: 'Annual Corporate Accounting',
      img: '/Assets/image_13.jpg',
      para1: 'Compiling annual financial accounts requires total data accuracy to protect your company standing at Companies House. Our practice has been structuring statutory financial statements for business owners for over 35 years.',
      para2: 'We convert your raw transaction books into clear balance sheets and formal profit summaries. This process tracks every business movement accurately, providing a strong financial record that supports future banking requests or funding reviews.',
      items: ['Statutory accounts compilation and balancing', 'Companies House direct portal indexing', 'Director reporting statements configuration', 'Micro-entity and small business template customisation']
    },
    {
      slug: 'audit',
      title: 'Statutory Auditing Services',
      img: '/Assets/image_8.jpg',
      para1: 'As registered statutory auditors regulated by the Association of Chartered Certified Accountants, we provide authoritative independent financial examinations. We analyze internal corporate data paths to confirm reporting validity.',
      para2: 'Our risk mitigation approach looks closely at hidden structural liabilities, identifies transaction anomalies, and strengthens your administrative control layers. This process provides a verified statement that builds deep market trust with corporate shareholders.',
      items: ['Independent financial statement verification', 'Internal corporate control system auditing', 'Fraud prevention checks and security tests', 'ACCA compliant statutory report delivery']
    },
    {
      slug: 'tax',
      title: 'Corporate & Personal Tax Planning',
      img: '/Assets/image_6.png',
      para1: 'Managing taxation requirements demands advanced long-term planning frameworks to protect your hard-earned corporate assets. We build custom tax strategies that reduce business liabilities while ensuring full legal compliance.',
      para2: 'We review your entire operational structure to maximize capital allowances, handle complex director remuneration rules, and manage family wealth transfer plans. This careful planning ensures your corporate entities retain maximum liquidity throughout the fiscal year.',
      items: ['Corporate tax return calculation and filing', 'Capital gains tax minimization strategies', 'Director dividend payment plan engineering', 'Inheritance and corporate asset wealth protection']
    },
    {
      slug: 'payroll',
      title: 'Comprehensive Payroll & RTI Management',
      img: '/Assets/image_14.jpg',
      para1: 'Processing staff salaries involves complex data requirements and strict timeline dependencies. Our complete payroll module manages employee calculations seamlessly, running automated real-time information submissions behind a hardened perimeter.',
      para2: 'We compute tax deductions, handle student loan updates, and maintain workplace pension auto-enrolment records. This structured management ensures that your workforce receives precise digital statements on time while fulfilling all HMRC compliance mandates.',
      items: ['Customized digital slip generation loops', 'Real-Time Information submission file handling', 'Workplace auto-enrolment pension plan updates', 'Year-end documentation and P60 output tracking']
    },
    {
      slug: 'business-start-ups',
      title: 'Strategic Business Start Ups Planning',
      img: '/Assets/image_10.jpg',
      para1: 'Launching a new commercial venture requires setting up strong corporate foundations right from the start. We replace poorly designed template structures with an elite corporate planning system that helps local founders establish their entities securely.',
      para2: 'We help you choose the best business structure, manage registrations for essential tax accounts, and set up your initial banking pathways. This careful preparation prevents compliance errors, giving your new enterprise a clear path toward sustainable local growth.',
      items: ['Limited company incorporation setup tracking', 'HMRC corporate tax activation registration', 'Initial financial plan accounting layouts', 'Strategic business structure analysis']
    },
    {
      slug: 'corporate-finance',
      title: 'Corporate Finance & Transaction Advisory',
      img: '/Assets/image_9.jpg',
      para1: 'Securing capital for business expansion or managing corporate transactions requires expert strategic guidance. Our advisory framework handles capital restructuring and acquisition funding assessments with total professional discretion.',
      para2: 'We perform deep due diligence checks to evaluate market opportunities and identify hidden transaction risks. This detailed analysis ensures company directors enter mergers, acquisitions, or fundraising rounds with strong strategic data behind them.',
      items: ['Commercial capital sourcing strategies', 'Corporate acquisition due diligence audits', 'Business valuation matrix modeling', 'Disposal strategy and transaction protection plans']
    },
    {
      slug: 'company-statutory-records',
      title: 'Company Statutory Records Maintenance',
      img: '/Assets/image_15.jpg',
      para1: 'Fulfilling statutory documentation requirements is a continuous legal obligation for all registered corporate entities. Missing confirmation deadlines can lead to significant penalties and risk domain strike-off notices.',
      para2: 'We take over this administrative burden completely by maintaining your company registers, tracking share allocation changes, and handling all Companies House updates. This reliable oversight ensures your corporate structure remains clean and fully compliant throughout the year.',
      items: ['Confirmation statement execution monitoring', 'Share register documentation changes', 'Director appointment tracking management', 'Historical minute book storage maintenance']
    },
    {
      slug: 'enquiries-investigations',
      title: 'HMRC Enquiries & Investigations Support',
      img: '/Assets/image_13.jpg',
      para1: 'Facing an unexpected HMRC corporate tax investigation can be highly stressful and disrupt daily business operations. We provide expert defensive support to protect company directors during detailed tax reviews.',
      para2: 'We act as your direct professional interface with tax authorities, managing all documentation requests and validating your transaction data. This strong defense limits financial exposure, prevents unfair penalties, and resolves tax disputes efficiently.',
      items: ['Direct technical interface for all HMRC contact', 'Data analysis and transaction evidence checks', 'Dispute resolution and appeals management', 'Tax penalty mitigation strategy designs']
    },
    {
      slug: 'research-development-claims',
      title: 'Research & Development Tax Credits',
      img: '/Assets/image_16.jpg',
      para1: 'The UK government provides valuable tax incentives for innovative firms, yet many small businesses miss out on R&D tax relief due to complex application rules. We use specialized financial engineering to uncover these qualifying activities within your workflows.',
      para2: 'We analyze your project investments, separate qualifying development costs, and compile the technical reports required by tax authorities. This professional preparation accelerates your application, unlocking significant cash injections to reinvest back into your business.',
      items: ['Technical development project qualification checks', 'Eligible staff and materials cost tracking', 'Comprehensive R&D report compilation', 'Direct management of incentive claims with HMRC']
    }
  ];

  return serviceMatrix.map(srv => ({
    params: { slug: srv.slug },
    props: { srv }
  }));
}

const { srv } = Astro.props;
---
<Layout title={`${srv.title} Sector Directory`} description={srv.para1}>
  
  <section class="relative bg-[#0b132b] text-white py-24 border-b border-[#3a506b] overflow-hidden">
    <div class="absolute inset-0 opacity-20 bg-cover bg-center" style={`background-image: url('${srv.img}');`}></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0b132b] via-[#0b132b]/90 to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-4 text-xs text-cyan-400 font-bold tracking-wider uppercase">
        <a href="/" class="hover:underline">Corporate Core</a> &gt; <span class="text-white">Sectors</span>
      </nav>
      <h1 class="text-3xl sm:text-5xl font-black tracking-tight text-white max-w-3xl leading-tight">{srv.title}</h1>
    </div>
  </section>

  <section class="w-full py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        
        <div class="lg:col-span-2 space-y-6 text-base text-slate-600 leading-relaxed">
          <p class="font-medium text-[#0b132b] text-lg">{srv.para1}</p>
          <p>{srv.para2}</p>
          
          <div class="pt-8">
            <h3 class="text-lg font-bold text-[#0b132b] uppercase tracking-wider mb-6">Service Scope Parameters</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {srv.items.map(item => (
                <div class="flex items-start space-x-3 bg-slate-50 rounded-lg border border-slate-100 p-4">
                  <span class="text-cyan-400 font-black">✓</span>
                  <span class="text-xs font-semibold text-[#0b132b]">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-[#0b132b] text-white p-8 rounded-xl border border-[#3a506b] shadow-xl space-y-6">
            <h4 class="text-sm font-bold uppercase tracking-widest text-cyan-400">Secure Account Entry</h4>
            <p class="text-xs text-slate-300 leading-relaxed">
              Existing clients can access live transaction boards or transfer statutory documentation through our main external verification channels.
            </p>
            <div class="space-y-3 pt-2">
              <a href="https://securedwebapp.com/login.asp?p=8155" target="_blank" rel="noopener noreferrer" class="w-full text-center py-3 bg-transparent border border-cyan-400 text-white hover:bg-cyan-400 hover:text-[#0b132b] text-xs font-bold uppercase tracking-wider rounded transition-all block">
                Bookkeeping Console
              </a>
              <a href="https://johalandcompany.irisopenspace.co.uk/" target="_blank" rel="noopener noreferrer" class="w-full text-center py-3 bg-cyan-400 text-[#0b132b] hover:bg-white text-xs font-bold uppercase tracking-wider rounded transition-all block font-black">
                Iris Compliance Portal
              </a>
            </div>
          </div>

          <div class="bg-slate-50 p-8 rounded-xl border border-slate-200 text-center">
            <h4 class="text-xs font-bold uppercase tracking-widest text-[#0b132b] mb-2">Hornchurch Telephone Hub</h4>
            <div class="text-xl font-black text-[#3a506b]">01708 444 214</div>
            <p class="text-[10px] text-slate-500 mt-2">Available business hours Monday through Friday for emergency consultation scheduling.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
