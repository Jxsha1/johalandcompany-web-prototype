---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const serviceMatrix = [
    {
      slug: 'bookkeeping',
      title: 'Bookkeeping Services',
      img: '/Assets/image_8.jpg',
      para1: 'We offer a bookkeeping service tailored to your requirements. We can assist in keeping records on your behalf from our premises or alternatively our staff can be sent to you to assist you directly.',
      para2: 'Our services also include an advisory role where you can keep the records yourself and just ask us periodically to review your books, and provide advice. Alternatively we can arrange a member of our staff to train you or your staff. This can include computer support and help in setting up computer software.',
      items: ['Digital transaction indexing and processing', 'Reconciliation loops against bank paths', 'Cloud asset receipt scanning integration', 'Continuous ledger data balancing adjustments']
    },
    {
      slug: 'vat',
      title: 'VAT Compliance & Advisory',
      img: '/Assets/image_9.jpg',
      para1: 'We can help prepare your VAT returns on your behalf. This can be combined with the bookkeeping service.',
      para2: 'We offer a VAT advisory role where we can assist you with VAT queries, planning, registration and de-registration. Our expertise will suit all of your requirements, no matter how complex.',
      items: ['Making Tax Digital secure API processing', 'Quarterly tax liability analytics reports', 'Input versus output calculation reviews', 'Direct representation during HMRC status checks']
    },
    {
      slug: 'accounting',
      title: 'Annual Accounting & Projections',
      img: '/Assets/image_10.jpg',
      para1: 'We can prepare sole trader, partnership, rental, trust, pension scheme and limited company accounts. Depending on your requirements, these can be prepared from basic prime records or from your own bookkeeping systems.',
      para2: 'We can also assist in preparing management accounts, cash flow reports and projected accounts. More than just preparing your accounts, we can also help you to understand the figures, so that they assist you in planning, managing and controlling your business.',
      items: ['Statutory accounts compilation and balancing', 'Companies House direct portal indexing', 'Director reporting statements configuration', 'Micro-entity and small business template customisation']
    },
    {
      slug: 'audit',
      title: 'ACCA Registered Statutory Audit',
      img: '/Assets/image_11.jpg',
      para1: 'We are registered auditors and carry out audits of limited companies or any other entities to help meet regulations or requirements of clients.',
      para2: 'We ensure that the latest audit techniques are employed so as to be efficient but cost effective. We can also review your internal control and accounting systems with recommendations for improvement.',
      items: ['Independent financial statement verification', 'Internal corporate control system auditing', 'Fraud prevention checks and security tests', 'ACCA compliant statutory report delivery']
    },
    {
      slug: 'tax',
      title: 'Corporate & Personal Tax Planning',
      img: '/Assets/image_12.jpg',
      para1: 'We offer a compliance service via online filing of corporation tax returns for limited companies and also self assessment returns for individuals, partners, trusts and pension schemes.',
      para2: 'More than this we can offer tax planning advice to suit your own personal needs and in a variety of different situations. This includes capital gains tax, corporation tax, income tax and inheritance tax.',
      items: ['Corporate tax return calculation and filing', 'Capital gains tax minimization strategies', 'Director dividend payment plan engineering', 'Inheritance and corporate asset wealth protection']
    },
    {
      slug: 'payroll',
      title: 'Payroll & Workplace Auto-Enrolment',
      img: '/Assets/image_13.jpg',
      para1: 'We can run a payroll on behalf of your business in house, including subcontractors and online filing of all month end and year end returns. We can assist you with running your own system and help in month end and year end procedures and other queries.',
      para2: 'We can administer and advise on the set up of Auto Enrolment Pension and prepare the monthly submissions to the pension provider. We can also give advice on and prepare P11D\'s, reporting Expenses and Benefits for Directors and Employees.',
      items: ['Customized digital slip generation loops', 'Real-Time Information submission file handling', 'Workplace auto-enrolment pension plan updates', 'Year-end documentation and P60 output tracking']
    },
    {
      slug: 'business-start-ups',
      title: 'Strategic Business Start Ups Infrastructure',
      img: '/Assets/image_14.jpg',
      para1: 'We can provide advice on the type of undertaking to set up depending on your circumstances. This could be Limited Company, Partnership, LLP, Self Employment. We will also deal with all aspects of registering with HM Revenue & Customs online and Companies House.',
      para2: 'Our staff understand that for new start ups it is difficult to understand the complexities of forms and taxation requirements. Therefore, we will provide extensive guidance in these important first steps so that the business can start flourishing.',
      items: ['Limited company incorporation setup tracking', 'HMRC corporate tax activation registration', 'Initial financial plan accounting layouts', 'Strategic business structure analysis']
    },
    {
      slug: 'corporate-finance',
      title: 'Corporate Finance & Transaction Advisory',
      img: '/Assets/image_15.jpg',
      para1: 'We can provide advice on the structure of purchase and sale agreements to suit individual requirements and also to mitigate tax burdens.',
      para2: 'We have expertise in working alongside solicitors and banks to ensure the process runs smoothly. Due diligence and investigative reports can be prepared on target businesses.',
      items: ['Commercial capital sourcing strategies', 'Corporate acquisition due diligence audits', 'Business valuation matrix modeling', 'Disposal strategy and transaction protection plans']
    },
    {
      slug: 'company-statutory-records',
      title: 'Company Statutory Records Maintenance',
      img: '/Assets/image_16.jpg',
      para1: 'We can help you set up a limited company and file all the required forms and returns online. Our address is also used as a registered office by clients as we maintain their statutory records to meet Companies Act requirements.',
      para2: 'Our administrative protection tracks company records meticulously, eliminating continuous regulatory strike off threats from third party bodies.',
      items: ['Confirmation statement execution monitoring', 'Share register documentation changes', 'Director appointment tracking management', 'Historical minute book storage maintenance']
    },
    {
      slug: 'enquiries-investigations',
      title: 'HMRC Enquiries & Investigations Support',
      img: '/Assets/image_17.jpg',
      para1: 'Our experience and professional approach can assist you in dealing with complexities and stress of all types of enquiry, routine and non-routine. We can assist in all self assessment, corporation tax, VAT and PAYE/NIC visits and enquiries and at all levels.',
      para2: 'In order to help reduce the burden of potential problems on future visits we provide a PAYE/NIC and VAT "health check". We can review your current systems and provide advice and recommendations for improvement.',
      items: ['Direct technical interface for all HMRC contact', 'Data analysis and transaction evidence checks', 'Dispute resolution and appeals management', 'Tax penalty mitigation strategy designs']
    },
    {
      slug: 'research-development-claims',
      title: 'Research & Development Tax Credits',
      img: '/Assets/image_18.jpg',
      para1: 'Research and Development Relief is a Corporation Tax relief that may reduce your company or organisation\'s tax bill. On the assumption that the company qualifies as an SME with fewer than 500 employees and an annual turnover not exceeding £100m or with a balance sheet total not exceeding £86m, the company may be entitled to claim tax relief of 230% on allowable R & D expenditure after 1 April 2015.',
      para2: 'As a general guideline, R & D tax credits can be claimed on the cost of employing staff who are directly or actively engaged in carrying out the research and development, the cost of the materials that are used in the research and development and on payments made to subcontractors that are assisting with the research and development.',
      items: ['Technical development project qualification checks', 'Eligible staff and materials cost tracking', 'Comprehensive R&D report compilation', 'Direct management of incentive claims with HMRC']
    }
  ];

  return serviceMatrix.map(srv => ({
    params: { slug: srv.slug },
    props: { srv }
  }));
}

const { srv } = Astro.props;
---
<Layout title={`${srv.title} Sector Directory`} description={srv.para1}>
  
  <main class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        <div class="lg:col-span-6 space-y-6">
          <nav class="text-xs font-bold text-cyan-600 uppercase tracking-wider">
            <a href="/" class="hover:underline">Home</a> &gt; <span class="text-slate-400">Services</span>
          </nav>
          <h1 class="text-3xl font-black tracking-tight text-[#0b132b]">{srv.title}</h1>
          
          <div class="text-slate-600 text-sm leading-relaxed space-y-4 font-normal">
            <p class="text-base text-[#0b132b] font-medium leading-normal">{srv.para1}</p>
            <p>{srv.para2}</p>
          </div>

          <div class="pt-6 border-t border-slate-100 flex flex-col sm:flex-row gap-4">
            <a href="https://securedwebapp.com/login.asp?p=8155" target="_blank" rel="noopener noreferrer" class="text-center px-6 py-3 bg-[#0b132b] text-white text-xs font-bold uppercase tracking-wider rounded-md hover:bg-[#3a506b] transition-colors">
              Bookkeeping Gateway
            </a>
            <a href="https://johalandcompany.irisopenspace.co.uk/" target="_blank" rel="noopener noreferrer" class="text-center px-6 py-3 bg-cyan-400 text-[#0b132b] text-xs font-bold uppercase tracking-wider rounded-md hover:bg-[#0b132b] hover:text-white transition-all">
              Iris OpenSpace Portal
            </a>
          </div>
        </div>

        <div class="lg:col-span-6 rounded-xl overflow-hidden border border-slate-200 shadow-xl bg-slate-100">
          <img src={srv.img} alt={`Visual depiction for ${srv.title}`} class="w-full h-auto object-cover" />
        </div>

      </div>
    </div>
  </main>
</Layout>
