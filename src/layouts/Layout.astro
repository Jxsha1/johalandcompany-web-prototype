---
import '../../styles/global.css';
import Header from '../components/Header.astro';

const { title, description = "Johal & Company has been operating for over 35 years as a trusted accountancy practice and registered statutory audit partnership in Hornchurch." } = Astro.props;
---
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Johal & Company</title>
  </head>
  <body class="bg-corporate-slateLight text-corporate-navy font-sans antialiased selection:bg-corporate-accentIce selection:text-corporate-navy">
    
    <Header />
    
    <slot />

    <footer class="bg-corporate-navy text-corporate-slateLight border-t border-corporate-premiumBlue py-16 relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 border-b border-slate-800 pb-12 mb-12">
          
          <div class="space-y-4">
            <div class="flex items-center space-x-3">
              <img src="/src/assets/image_21.png" alt="Johal & Company Logo" class="h-8 w-auto bg-white p-1 rounded" />
              <span class="text-lg font-black tracking-wider text-white">JOHAL & COMPANY</span>
            </div>
            <p class="text-xs text-slate-400 leading-relaxed">
              Providing peerless financial accounting protection, bespoke corporate governance strategies, and authoritative statutory auditing for over three decades across Essex.
            </p>
          </div>

          <div class="space-y-4">
            <h4 class="text-sm font-bold uppercase tracking-widest text-corporate-accentIce">Operational Headquarters</h4>
            <p class="text-xs text-slate-400 leading-relaxed">
              Spectrum House<br />
              2b Suttons Lane<br />
              Hornchurch, Essex RM12 6RJ
            </p>
            <div class="text-xs text-corporate-slateLight font-semibold">
              T: 01708 444 214 | E: group@johalandcompany.com
            </div>
          </div>

          <div class="space-y-4">
            <h4 class="text-sm font-bold uppercase tracking-widest text-corporate-accentIce">Regulatory Alignment</h4>
            <div class="flex items-center space-x-4">
              <img src="/src/assets/image_2.png" alt="ACCA Registered Badge" class="h-10 w-auto object-contain bg-white p-1 rounded" />
              <img src="/src/assets/image_3.png" alt="Havering Excellence Seal" class="h-10 w-auto object-contain bg-white p-1 rounded" />
            </div>
            <p class="text-[10px] text-slate-500 leading-relaxed">
              Registered as auditors and regulated for a range of investment activities in the United Kingdom by the Association of Chartered Certified Accountants.
            </p>
          </div>

        </div>

        <div class="flex flex-col sm:flex-row items-center justify-between text-xs text-slate-500">
          <p>© 2026 Johal & Company. All technical assets secured via serverless edge layers.</p>
          <div class="flex space-x-6 mt-4 sm:mt-0">
            <a href="/privacy" class="hover:text-corporate-accentIce transition-colors underline">Privacy Policy Hub</a>
            <a href="/terms" class="hover:text-corporate-accentIce transition-colors underline">Terms of Engagement</a>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>