---
import '../styles/global.css';
import Header from '../components/Header.astro';

const { title, description = "Johal & Company has been operating for over 35 years as a trusted accountancy practice and registered statutory audit partnership in Hornchurch, Essex." } = Astro.props;
---
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <!-- Appended version query string to bypass stubborn browser icon caching mechanisms -->
    <link rel="icon" type="image/png" href="/Assets/image_6.png?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Johal & Company</title>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased selection:bg-cyan-400 selection:text-slate-900">
    
    <Header />
    
    <slot />

    <footer class="bg-[#0b132b] text-slate-200 border-t border-[#3a506b] py-16 relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 border-b border-slate-800 pb-12 mb-12">
          
          <div class="space-y-4">
            <div class="flex items-center space-x-3">
              <img src="/Assets/image_6.png" alt="Johal & Company Logo" class="h-10 w-auto bg-white p-1 rounded object-contain" />
              <span class="text-lg font-black tracking-wider text-white">JOHAL & COMPANY</span>
            </div>
            <p class="text-xs text-slate-400 leading-relaxed">
              Providing peerless financial accounting protection, bespoke corporate governance strategies, and authoritative statutory auditing for over three decades across Essex.
            </p>
          </div>

          <div class="space-y-4">
            <h4 class="text-sm font-bold uppercase tracking-widest text-cyan-400">Operational Headquarters</h4>
            <p class="text-xs text-slate-400 leading-relaxed">
              Spectrum House<br />
              2b Suttons Lane<br />
              Hornchurch, Essex RM12 6RJ
            </p>
            <div class="text-xs text-slate-200 font-semibold">
              T: 01708 444 214 | E: group@johalandcompany.com
            </div>
          </div>

          <div class="space-y-4">
            <h4 class="text-sm font-bold uppercase tracking-widest text-cyan-400">Partner & Regulatory Grid</h4>
            <div class="flex flex-wrap items-center gap-3">
              <img src="/Assets/image_2.png" alt="Upminster Accountants Logo" class="h-10 w-auto object-contain bg-white p-1 rounded" />
              <img src="/Assets/image_3.png" alt="The Startup Planners Logo" class="h-10 w-auto object-contain bg-white p-1 rounded" />
              <img src="/Assets/image_4.png" alt="The Best of Havering Logo" class="h-10 w-auto object-contain bg-white p-1 rounded" />
              <img src="/Assets/image_5.png" alt="ACCA Registered Badge" class="h-10 w-auto object-contain bg-white p-1 rounded" />
            </div>
            <p class="text-[10px] text-slate-500 leading-relaxed pt-2">
              Registered as auditors and regulated for a range of investment activities in the United Kingdom by the Association of Chartered Certified Accountants.
            </p>
          </div>

        </div>

        <div class="flex flex-col sm:flex-row items-center justify-between text-xs text-slate-500">
          <p>© 2026 Johal & Company. All technical assets secured via serverless edge layers.</p>
          <div class="flex space-x-6 mt-4 sm:mt-0">
            <a href="/privacy" class="hover:text-cyan-400 transition-colors underline">Privacy Policy Hub</a>
            <a href="/terms" class="hover:text-cyan-400 transition-colors underline">Terms of Engagement</a>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
